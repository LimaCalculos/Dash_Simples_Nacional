# ============================================================
# Simples Dashboard — Configuração
# Copie para .env e preencha com seus valores reais
# ============================================================

# --- Banco de dados ---
DATABASE_URL=sqlite:///./data/simples.db

# --- JWT ---
SECRET_KEY=troque-por-uma-chave-secreta-forte-aqui-64chars
ACCESS_TOKEN_EXPIRE_HOURS=8

# --- Google OAuth2 (para login dos funcionários) ---
# Tipo: Web Application no Google Cloud Console
# Authorized redirect URIs: http://localhost:5174/auth/callback
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu-client-secret

# --- Google Drive (para acesso à pasta de declarações) ---
# Tipo: Desktop Application no Google Cloud Console
# Baixar credentials.json e colocar na pasta backend/
GOOGLE_DRIVE_CREDENTIALS_FILE=./credentials.json
GOOGLE_DRIVE_TOKEN_FILE=./token.json

# ID da pasta raiz no Google Drive
# Abra a pasta no browser: o ID é o trecho após /folders/ na URL
DRIVE_ROOT_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# --- Intervalo de polling do Drive (em minutos) ---
DRIVE_POLL_INTERVAL_MINUTES=5

# --- Segurança: e-mails autorizados (separados por vírgula) ---
# Somente estes e-mails Google podem acessar o dashboard
ALLOWED_EMAILS=funcionario1@limacalculos.com.br,funcionario2@limacalculos.com.br

# --- CORS ---
CORS_ORIGINS=http://localhost:5174

# --- Ambiente ---
DEBUG=true
LOG_LEVEL=INFO
